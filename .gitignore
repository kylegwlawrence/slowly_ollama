# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.coverage

# Virtualenv
.venv/

# Local config (may contain secrets / host-specific paths)
.env

# SQLite databases (data lives in ~/Library/Application Support/, but ignore
# any stray .db files that land in the repo during development)
*.db
*.db-journal
*.db-wal
*.db-shm

# macOS
.DS_Store

# Editors
.vscode/
.idea/
*.swp

# Claude Code's per-project local settings (e.g. tool permissions)
.claude/

# Ignore the agent workspace's runtime data (chats, generated outlines, etc.)
# but track the shared templates folder so the curriculum scaffolding is
# version-controlled.
/agent_workspace/*
!/agent_workspace/_templates/
!/agent_workspace/_templates/**
ext_plan.md
/docs/