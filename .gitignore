# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.coverage

# Virtualenv
.venv/

# Local config (may contain secrets / host-specific paths)
.env

# SQLite databases and runtime data
/data/
*.db
*.db-journal
*.db-wal
*.db-shm

# macOS
.DS_Store

# Editors
.vscode/
.idea/
*.swp

# Claude Code's per-project local settings (e.g. tool permissions)
.claude/

# Ignore the agent workspace's runtime data (chats, generated outlines, etc.)
# but track the shared templates folder so the curriculum scaffolding is
# version-controlled.
/agent_workspace/*
!/agent_workspace/_education_course_templates/
!/agent_workspace/_education_course_templates/**
# AUDIT.md is specific to the physics-lessons corpus — keep it on disk but untracked.
/agent_workspace/_education_course_templates/AUDIT.md
ext_plan.md
/docs/