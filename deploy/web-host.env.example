# slollillama environment for a SPLIT (two-machine) deployment, web tier (web-host).
#
# Copy to the repo root as `.env` and replace every <placeholder>:
#   cp deploy/web-host.env.example .env
#
# Placeholders:
#   <gpu-host>  → DNS name of the machine running Ollama and
#                 holding the DB/workspace mirror (e.g. "gpu-box")
#   <pi-user>   → the Linux user on web-host (e.g. "pi")
#
# See docs/plans/phase23-split-deployment.md for the full runbook.
# ---------------------------------------------------------------------------

# Ollama runs on the OTHER machine, reached over your private network. The
# Ollama host there must bind beyond localhost (Ollama defaults to 127.0.0.1,
# which the private network can't reach):
#   sudo systemctl edit ollama
#   [Service]
#   Environment="OLLAMA_HOST=0.0.0.0:11434"
#   sudo systemctl restart ollama
# Verify from web-host:  curl http://<gpu-host>:11434/api/tags
OLLAMA_HOST=http://<gpu-host>:11434

# Live SQLite DB — stays LOCAL to web-host. SQLite is an embedded file database,
# not a network service, so the live DB cannot safely live on another
# machine. Durability comes from the mirror below. Linux path; the parent
# directory is created on first run. `~` also expands.
DB_PATH=/home/<pi-user>/.local/share/slollillama/chats.db

# Agent workspace — also LOCAL to web-host, because the file tools
# (read_file / write_file / list_directory / search_files) execute
# server-side on the web tier. Leave unset to disable the file tools.
FILE_TOOL_ROOT=/home/<pi-user>/slollillama_workspace

# Remote mirror (Phase 20 backup). On every send / generation-complete /
# successful write_file, the app pushes a WAL-consistent copy of the DB and
# the workspace tree to <gpu-host>. This is what puts your data "on the
# other machine" without the fragility of networked SQLite.
#
# Requires NON-INTERACTIVE ssh key auth web-host -> <gpu-host>: the backup uses
# `ssh -o BatchMode=yes`, so a password/passphrase prompt = a silent backup
# failure. Test first:  ssh <gpu-host> true   (must succeed with no prompt).
#
# Both are rsync/ssh specs in host:/path form. The remote dirs are created
# automatically (mkdir -p) on first push.
REMOTE_DB_PATH=<gpu-host>:/srv/slollillama/db
REMOTE_PATH=<gpu-host>:/srv/slollillama/workspaces

# Optional: GitHub PAT for the fetch_github_file tool. Public repos work
# without it (60 req/hr); set it to unlock private repos + 5000 req/hr.
# GITHUB_TOKEN=
