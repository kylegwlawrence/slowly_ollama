# Template for .env — copy to .env and adjust as needed.
# .env is gitignored; this file is committed.

# Base URL of the local Ollama HTTP API.
OLLAMA_HOST=http://localhost:11434

# SQLite database path. `~` expands to the current user's home directory.
DB_PATH=~/Library/Application Support/ollama_slowly/chats.db

# Workspace directory the file tools (read_file / write_file) are
# confined to. All paths are resolved relative to this dir and anything
# escaping it (via `..`, an absolute path, or a symlink) is rejected.
# Leave unset to disable the file tools entirely (they're removed from
# the tool registry, so the model is never offered them). `~` expands to
# the current user's home directory.

FILE_TOOL_ROOT=./agent_workspace

# Optional GitHub personal access token for the `fetch_github_file` tool.
# Leave unset to fetch public files anonymously (60 req/hr). Set it to a
# PAT to unlock private repos and the 5000 req/hr authenticated quota.
# GITHUB_TOKEN=

# Optional second Ollama instance running on another machine (LAN or
# VPN-reachable). When BOTH REMOTE_OLLAMA_HOST and
# REMOTE_OLLAMA_MODEL are set, the "Remote" agent shows up in the chat
# header dropdown and routes its inference (and compaction) to that
# host. Tools still execute on this server; only inference is remote.
# Either var unset → agent is dropped from the registry entirely.
# REMOTE_OLLAMA_HOST=http://host1:11434
# REMOTE_OLLAMA_MODEL=llama3.1:70b

# copy_to_pi.py defaults
COPY_SOURCE=agent_workspace
COPY_PIHOST=host
COPY_DEST=dest/folder