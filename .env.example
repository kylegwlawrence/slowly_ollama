# Template for .env — copy to .env and adjust as needed.
# .env is gitignored; this file is committed.

# Base URL of the local Ollama HTTP API.
OLLAMA_HOST=http://localhost:11434

# SQLite database path. Relative to the repo root.
DB_PATH=./data/chats.db

# Workspace directory the file tools (read_file / write_file) are
# confined to. All paths are resolved relative to this dir and anything
# escaping it (via `..`, an absolute path, or a symlink) is rejected.
# Leave unset to disable the file tools entirely (they're removed from
# the tool registry, so the model is never offered them). `~` expands to
# the current user's home directory.

FILE_TOOL_ROOT=./agent_workspace

# Optional GitHub personal access token for the `fetch_github_file` tool.
# Leave unset to fetch public files anonymously (60 req/hr). Set it to a
# PAT to unlock private repos and the 5000 req/hr authenticated quota.
# GITHUB_TOKEN=

# Self-hosted SearXNG base URL for the `web_search` tool. Unset → no web
# search (the tool is dropped from the registry, so the model is never
# offered it). The app only ever talks to this local SearXNG; SearXNG is
# what reaches the internet. Run it bound to loopback (127.0.0.1) with JSON
# output enabled and the bot limiter relaxed — see the README setup section.
# SEARXNG_URL=http://localhost:8888

# Additional Ollama machines (LAN or VPN-reachable). The primary host
# above is always the default; these are extra machines you can route a chat
# to from the header machine picker, each offering its own models in the
# single model dropdown. Add as many as you like — no code change needed.
#
# OLLAMA_EXTRA_HOSTS is a JSON array of objects, each requiring `name`, `url`,
# and `default_model` (`label` is optional, defaults to `name`). Tools still
# execute on this server; only inference is offloaded to the chosen machine.
# OLLAMA_EXTRA_HOSTS=[{"name":"host2","label":"host2","url":"http://host2:11434","default_model":"llama3.1:70b"}]
#
# Legacy single-host fallback: when OLLAMA_EXTRA_HOSTS is unset, BOTH of these
# (if set) register one "host2" machine. Prefer OLLAMA_EXTRA_HOSTS for new
# setups; either var unset → the host is dropped from the picker.
# SLOWLY_OLLAMA_HOST=http://host2:11434
# SLOWLY_OLLAMA_MODEL=llama3.1:70b

# Remote backup/sync destinations (Phase 20). When BOTH REMOTE_PATH and
# REMOTE_DB_PATH are set, the app automatically pushes the workspaces and
# the SQLite database to these locations whenever a message is sent,
# generation completes, or a `write_file` succeeds (single-flight +
# debounced, fire-and-forget). Pushes overwrite a single canonical mirror
# and are no-ops when the remote host is unreachable. Either var unset →
# automatic backups are disabled entirely. Restore is manual and pull-only
# (run `python app/copy_agent_workspace.py --all`; see the deployment
# section of `README.md`).
#
# Both are rsync/ssh remote specs in `host:/path` form. The host must be
# reachable over SSH with key auth (test: `ssh <host> true`).
#
# REMOTE_PATH      → directory the agent workspaces mirror into.
# REMOTE_DB_PATH   → directory `chats.db` is dropped into.
REMOTE_PATH=host:/dest/agent_workspaces
REMOTE_DB_PATH=host:/dest/slollillama_chats

# Fallback local workspace destination for `copy_agent_workspace.py` restores
# (used only when FILE_TOOL_ROOT is unset).
LOCAL_PATH=agent_workspace