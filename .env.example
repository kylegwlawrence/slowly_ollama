OLLAMA_HOST=http://localhost:11434

OLLAMA_CHAT_TIMEOUT=600
OLLAMA_UTIL_TIMEOUT=30

DB_PATH=./data/chats.db
FILE_TOOL_ROOT=./agent_workspace

SEARXNG_URL=http://localhost:8888

# OLLAMA_EXTRA_HOSTS is a JSON array of objects, each requiring `name`, `url`,
# and `default_model` (`label` is optional, defaults to `name`). Tools still
# execute on this server; only inference is offloaded to the chosen machine.
OLLAMA_EXTRA_HOSTS=[{"name":"host2","label":"host2","url":"http://host2:11434","default_model":"llama3.1:70b"}]

REMOTE_PATH=host:/dest/agent_workspaces
REMOTE_DB_PATH=host:/dest/slollillama_chats
