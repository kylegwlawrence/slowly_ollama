# Template for .env — copy to .env and adjust as needed.
# .env is gitignored; this file is committed.

# Base URL of the local Ollama HTTP API.
OLLAMA_HOST=http://localhost:11434

# SQLite database path. Relative to the repo root.
DB_PATH=./data/chats.db

# Workspace directory the file tools (read_file / write_file) are
# confined to. All paths are resolved relative to this dir and anything
# escaping it (via `..`, an absolute path, or a symlink) is rejected.
# Leave unset to disable the file tools entirely (they're removed from
# the tool registry, so the model is never offered them). `~` expands to
# the current user's home directory.

FILE_TOOL_ROOT=./agent_workspace

# Optional GitHub personal access token for the `fetch_github_file` tool.
# Leave unset to fetch public files anonymously (60 req/hr). Set it to a
# PAT to unlock private repos and the 5000 req/hr authenticated quota.
# GITHUB_TOKEN=

# Optional second Ollama instance running on another machine (LAN or
# Tailscale-reachable). When BOTH REMOTE_OLLAMA_HOST and
# REMOTE_OLLAMA_MODEL are set, the "Remote" agent shows up in the chat
# header dropdown and routes its inference (and compaction) to that
# host. Tools still execute on this server; only inference is remote.
# Either var unset → agent is dropped from the registry entirely.
# REMOTE_OLLAMA_HOST=http://pop-os:11434
# REMOTE_OLLAMA_MODEL=llama3.1:70b

# Remote backup/sync destinations (Phase 20). When BOTH REMOTE_PATH and
# REMOTE_DB_PATH are set, the app automatically pushes the workspaces and
# the SQLite database to these locations whenever a message is sent,
# generation completes, or a `write_file` succeeds (single-flight +
# debounced, fire-and-forget). Pushes overwrite a single canonical mirror
# and are no-ops when the remote host is unreachable. Either var unset →
# automatic backups are disabled entirely. Restore is manual for now (see
# `copy_agent_workspace.py --source <host:/path>`).
#
# Both are rsync/ssh remote specs in `host:/path` form. The host must be
# reachable over SSH with key auth (test: `ssh <host> true`).
#
# REMOTE_PATH      → directory the agent workspaces mirror into.
# REMOTE_DB_PATH   → directory `chats.db` is dropped into.
REMOTE_PATH=host:/dest/agent_workspaces
REMOTE_DB_PATH=host:/dest/olliellama_chats

# copy_agent_workspace.py local-source default.
LOCAL_PATH=agent_workspace